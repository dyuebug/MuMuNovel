  ]);

  const applySingleStoryCreationSnapshot = useCallback((snapshot: StoryCreationSnapshot) => {
    singleStoryCreationAutoBriefRef.current = snapshot.isBriefCustomized
      ? MANUAL_STORY_CREATION_BRIEF_SENTINEL
