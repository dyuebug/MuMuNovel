                          {item.content.length > (isMobile ? 80 : 150) && '...'}

                        </div>

                      ) : (

                        <span style={{ color: 'rgba(0,0,0,0.45)', fontSize: isMobile ? 12 : 14 }}>闂佸搫妫楅崐鐟拔涢妶澶婄闁告侗鍙庨崯?/span>

                      )

                    }

                  />



                  {isMobile && (

                    <Space style={{ marginTop: 12, width: '100%', justifyContent: 'flex-end' }} wrap>

                      <Button

                        type="text"

