  const applyBatchStoryCreationSnapshot = useCallback((snapshot: StoryCreationSnapshot) => {
    batchStoryCreationAutoBriefRef.current = snapshot.isBriefCustomized
      ? MANUAL_STORY_CREATION_BRIEF_SENTINEL
