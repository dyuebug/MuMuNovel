                              </span>

                              <Space wrap size={isMobile ? 4 : 8}>

                                <Tag color={getStatusColor(item.status)}>{getStatusText(item.status)}</Tag>

                                <Badge count={`${item.word_count || 0}闁诲孩绋掗。纭?style={{ backgroundColor: 'var(--color-success)' }} />

