                              const isAnalyzing = task && (task.status === 'pending' || task.status === 'running');

                              const hasContent = item.content && item.content.trim() !== '';



                              return (

                                <Button

                                  type="text"

                                  icon={isAnalyzing ? <SyncOutlined spin /> : <FundOutlined />}

                                  onClick={() => handleShowAnalysis(item.id)}

                                  size="small"

